# Application
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./timeoff.sqlite

# HCM Integration
HCM_BASE_URL=http://localhost:4000
HCM_API_KEY=mock-hcm-api-key-secret
HCM_TIMEOUT_MS=10000
HCM_RETRY_ATTEMPTS=3
HCM_RETRY_DELAY_MS=1000

# Balance freshness threshold (in minutes)
BALANCE_STALE_THRESHOLD_MINUTES=5

# Webhook security
HCM_WEBHOOK_SECRET=mock-webhook-hmac-secret
